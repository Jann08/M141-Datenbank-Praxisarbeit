# ============================================================
# M141 Praxisarbeit – Backpacker_LB3
# Datei: my.cnf (lokale MariaDB-Konfiguration, XAMPP)
# Für: Entwicklung / lokaler Betrieb
# ============================================================

[mysqld]
# Zeichensatz
character-set-server    = utf8mb4
collation-server        = utf8mb4_unicode_ci

# InnoDB als Standard-Engine
default-storage-engine  = InnoDB

# Fremdschlüssel-Checks aktivieren
innodb_force_recovery   = 0

# Maximale Verbindungen (lokal)
max_connections         = 50

# Allgemein
port                    = 3306
bind-address            = 127.0.0.1

# Logging (für Entwicklung)
general_log             = 1
general_log_file        = logs/mariadb_general.log
slow_query_log          = 1
slow_query_log_file     = logs/mariadb_slow.log
long_query_time         = 2

[client]
default-character-set   = utf8mb4
port                    = 3306
host                    = localhost
